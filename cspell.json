{
  "version": "0.2",
  "language": "en",
  "dictionaries": ["bash", "npm", "node", "softwareTerms"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
